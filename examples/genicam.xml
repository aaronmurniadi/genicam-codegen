			<Sign>Unsigned</Sign>
			<Endianess>BigEndian</Endianess>
		</IntReg>
		<IntSwissKnife Name="AcquisitionStartLockedExpr">
			<pVariable Name="VAR_TLPARAMSLOCKED">TLParamsLocked</pVariable>
			<Formula>VAR_TLPARAMSLOCKED = 0</Formula>
		</IntSwissKnife>
